# ============================================================
# Production Environment Variables
# For use with Docker Portainer (Stack → Environment Variables)
# ============================================================
# Copy these into Portainer or into a .env file alongside
# docker-compose.prod.yml. Never commit real secrets to git.
# ============================================================

# ============================================================
# Project
# ============================================================
PROJECT_NAME=laravel
# Host path where persistent data (logs, etc.) is stored
DATA_PATH=/opt/data

# ============================================================
# Application (REQUIRED)
# ============================================================
APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com

# Generate with: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

APP_LOCALE=en
BCRYPT_ROUNDS=12

# ============================================================
# Logging
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ============================================================
# Database (REQUIRED)
# ============================================================
DB_DATABASE=laravel
DB_USERNAME=laravel_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================
# Redis
# Leave empty for no password (default)
# ============================================================
REDIS_PASSWORD=

# ============================================================
# Session / Cache
# ============================================================
SESSION_LIFETIME=120
# Set to your root domain to share session across subdomains
# e.g. .example.com
SESSION_DOMAIN=

# ============================================================
# Migrations
# true  = run migrations on every container start
# seed  = run migrations + seeders (use only for initial setup)
# false = skip migrations (safe default for production)
# ============================================================
RUN_MIGRATIONS=false

# ============================================================
# MinIO / S3 Storage (REQUIRED)
# ============================================================
MINIO_ROOT_USER=CHANGE_ME_ADMIN_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=laravel

# Public-facing MinIO domain (proxied via Nginx Proxy Manager)
MINIO_ENDPOINT=https://storage.example.com

# Full public URL for serving stored files (ENDPOINT + BUCKET)
MINIO_URL=https://storage.example.com/laravel

# ============================================================
# Mail
# Options: log | smtp | resend
# ============================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Laravel

# For SMTP
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=

# For Resend (https://resend.com)
RESEND_API_KEY=
